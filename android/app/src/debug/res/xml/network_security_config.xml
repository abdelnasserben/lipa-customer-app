<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only: permit cleartext HTTP to the local dev backend reached over an
     `adb reverse` tunnel (localhost) or the emulator host alias (10.0.2.2).
     This file lives under src/debug so it never ships in a release build. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
